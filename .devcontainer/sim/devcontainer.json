{
  "name": "sim",
  "build": { "dockerfile": "Dockerfile" },
  "remoteUser": "ubuntu",
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "GFDL_BASE": "${containerWorkspaceFolder}",
    "GFDL_ENV": "ubuntu_conda",
    "GFDL_WORK": "${containerWorkspaceFolder}/.isca_work",
    "GFDL_DATA": "${containerWorkspaceFolder}/.isca_data"
  },
  "postCreateCommand": "bash .devcontainer/sim/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "fortran-lang.linter-gfortran",
        "extractions.fortran-intellisense",
        "eamodio.gitlens",
        "vscodevim.vim"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "python.defaultInterpreterPath": "/home/dev/miniforge3/envs/isca_env/bin/python"
      }
    }
  }
}
