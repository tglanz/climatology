{
  "name": "climatology",
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "remoteUser": "ubuntu",
  "remoteEnv": {
    "GFDL_BASE": "${containerWorkspaceFolder}/submodules/isca",
    "GFDL_ENV": "ubuntu_conda",
    "GFDL_WORK": "${containerWorkspaceFolder}/.isca_work",
    "GFDL_DATA": "${containerWorkspaceFolder}/.isca_data"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.vscode-python-envs",
        "fortran-lang.linter-gfortran",
        "extractions.fortran-intellisense",
        "quarto.quarto",
        "eamodio.gitlens",
        "vscodevim.vim"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "python.analysis.extraPaths": [
          "${containerWorkspaceFolder}/submodules/isca/src/extra/python"
        ],
        "vim.enable": true
      }
    }
  }
}
